
# Payguru API credentials / config
PAYGURU_PRODUCT=mp
PAYGURU_BASE_URL=http://api.trend-tech.net
PAYGURU_MERCHANT_ID=3031
PAYGURU_SERVICE_IDS=3509,3513

# Runtime
DEBUG=0
API_TIMEOUT_SECONDS=120
API_MAX_RETRIES=3
API_RETRY_SLEEP_SECONDS=5

# Output behavior
# Default olarak CSV üretmez, doğrudan BigQuery'ye yazar.
# Lokal debug ihtiyacında WRITE_CSV=1 yapılabilir.
WRITE_CSV=0
OUT_DIR=./payguru_outputs

# BigQuery target
BQ_ENABLED=1
BQ_PROJECT_ID=microgain-9f959
BQ_DATASET=bc_t
BQ_TABLE=payguru_transactions_raw