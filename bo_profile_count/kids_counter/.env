# Base API
PROD_BASE_URL=https://api.gain.tv/2da7kf8jf

# Pagination / concurrency
PAGE_SIZE=100
MAX_PAGES=0
MAX_WORKERS=35
ENABLE_TQDM=0
PAUSE_EVERY_PAGES=50
PAUSE_SECONDS=10
HTTP_TIMEOUT_SECONDS=120

# Scan mode
SCAN_MODE=full
DATE_FIELD=updatedAt
LOOKBACK_DAYS=2

# Token store
# Local test: local token_store.json dosyasını okur/yazar.
# Prod MWAA tarafında bu değer DAG içinde TOKEN_STORE_MODE=s3 olarak set edilecek.
TOKEN_STORE_MODE=local
LOCAL_TOKEN_STORE_PATH=token_store.json

# Prod S3 token store reference
# Prod'da airflow_keys/token_store.json içindeki accessToken kullanılacak.
# Script 401 alırsa refreshToken varsa REFRESH_URL ile yenilemeyi dener.
S3_BUCKET=gain-data-airflow-bucket
S3_TOKEN_KEY=airflow_keys/token_store.json
REFRESH_URL=https://api.gain.tv/2da7kf8jf/TOKEN/refresh?__culture=tr-tr

# BigQuery / credentials
# Local testte gerekirse shell/env üzerinden override edilebilir.
BQ_PROJECT_ID=microgain-9f959
BQ_DATASET=bc_t