# =========================================================
# Target user selection
# =========================================================
# 1: BigQuery'den user_id listesi çekip sadece onları detail endpoint ile tara.
# 0: BO getUserList üzerinden sayfa sayfa tara.
USE_BIGQUERY_TARGET_USERS=1

BQ_PROJECT_ID=microgain-9f959
USER_VALID_UNTIL_LOOKBACK_DAYS=90

# Test/debug için limit. 0: limitsiz.
BQ_MAX_USERS=0

# Boş bırakılırsa kod içindeki default SQL kullanılır.
BQ_TARGET_USERS_SQL=

# =========================================================
# API scan performance
# =========================================================
# BO getUserList endpoint'i 100 üstünü kabul etmiyor.
PAGE_SIZE=100
MAX_WORKERS=100
MAX_RETRIES=3

# getUserList modu için. 0: tüm sayfalar.
MAX_PAGES=0

# =========================================================
# Result output
# =========================================================
SAVE_RESULT_TO_BIGQUERY=1
BQ_RESULT_TABLE=microgain-9f959.bc_t.multi_profile_counter

# =========================================================
# Optional filters
# =========================================================
# Profil createdAt filtresi gerekiyorsa YYYY-MM-DD formatında ver.
# Boş: profil oluşturma tarihine göre filtreleme yok.
PROFILE_CREATED_AFTER=

# Sadece getUserList modunda anlamlıdır. BigQuery modunda hedef user filtresi SQL tarafında yapılır.
FILTER_USER_VALID_UNTIL_IN_PYTHON=0

# Boş bırakılırsa default query kullanılır: NOT status:DELETED
USER_LIST_QUERY=

TIMEZONE=Europe/Istanbul