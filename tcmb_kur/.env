

# TCMB API config
TCMB_BASE_URL=https://www.tcmb.gov.tr/kurlar
TCMB_URL=https://www.tcmb.gov.tr/kurlar/today.xml

# Runtime
DEBUG=0
API_TIMEOUT_SECONDS=120
API_MAX_RETRIES=3
API_RETRY_SLEEP_SECONDS=5

# Output behavior
# Default olarak CSV üretmez, doğrudan BigQuery'ye yazar.
# Lokal debug ihtiyacında WRITE_CSV=1 yapılabilir.
WRITE_CSV=0
OUT_DIR=./tcmb_outputs

# BigQuery target
BQ_ENABLED=1
BQ_PROJECT_ID=microgain-9f959
BQ_DATASET=bc_t
BQ_TABLE=tcmb_exchange_rates_raw